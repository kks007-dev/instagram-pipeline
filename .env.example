# Telegram Bot Configuration
# Get this from BotFather on Telegram: https://t.me/botfather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Claude Code Routine Configuration
# Create a Routine at https://claude.ai/code/routines
# Copy the API trigger endpoint URL
ROUTINE_API_ENDPOINT=https://api.claude.ai/code/routines/your-routine-id/trigger

# Bearer token for authenticating with the Routine API
# This is provided when you set up the API trigger
ROUTINE_BEARER_TOKEN=your_routine_bearer_token_here

# Server Configuration
PORT=3000
NODE_ENV=production
